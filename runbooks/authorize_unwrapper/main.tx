addon "svm" {
    rpc_api_url = input.rpc_api_url
    network_id = input.network_id
}
variable "ext_swap_program" {
    value = "MSwapi3WhNKMUGm9YrxGhypgUEt7wYQH3ZgG32XoWzH"
}

variable "swap_global" {
    value = svm::find_pda(variable.ext_swap_program, ["global"])
}

signer "payer" "svm::secret_key" {
    description = "Pays fees for program deployments and operations"
    secret_key = input.local_signer
}

signer "authority" "svm::secret_key" {
    description = "Can upgrade programs and manage critical ops"
    secret_key = input.local_signer
}

action "set_swap_global" "std::send_http_request" {
  url = input.rpc_api_url
  method = "POST"
  body = {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "surfnet_setAccount",
    "params": [
      variable.swap_global,
    {
      "data": "",
      "executable": false,
      "lamports": 1000000000,
      "owner": variable.ext_swap_program,
      "rentEpoch": 0
    }
  ]
  }
}

