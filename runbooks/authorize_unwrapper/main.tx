addon "svm" {
    rpc_api_url = input.rpc_api_url
    network_id = input.network_id
}

variable "swap_global" {
    value = svm::find_pda("MSwapi3WhNKMUGm9YrxGhypgUEt7wYQH3ZgG32XoWzH", ["global"])
}

variable "m_ext_global" {
    value = svm::find_pda("wMXX1K1nca5W4pZr1piETe78gcAVVrEFi9f4g46uXko", ["global"])
}

signer "payer" "svm::secret_key" {
    description = "Pays fees for program deployments and operations"
    secret_key = input.local_signer
}

signer "authority" "svm::secret_key" {
    description = "Can upgrade programs and manage critical ops"
    secret_key = input.local_signer
}

action "set_swap_global" "std::send_http_request" {
  url = input.rpc_api_url
  method = "POST"
  body = {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "surfnet_setAccount",
    "params": [
      variable.swap_global.pda,
    {
      "data": "",
      "executable": false,
      "lamports": 1000000000,
      "owner": "MSwapi3WhNKMUGm9YrxGhypgUEt7wYQH3ZgG32XoWzH",
      "rentEpoch": 0
    }
  ]
  }
}

action "set_m_ext_global" "std::send_http_request" {
  url = input.rpc_api_url
  method = "POST"
  body = {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "surfnet_setAccount",
    "params": [
      variable.m_ext_global.pda,
    {
      "data": "",
      "executable": false,
      "lamports": 1000000000,
      "owner": "wMXX1K1nca5W4pZr1piETe78gcAVVrEFi9f4g46uXko",
      "rentEpoch": 0
    }
  ]
  }
}

output "status" {
  value = action.set_swap_global.status_code
}

output "response_body" {
  value = action.set_swap_global.response_body
}

action "get_m_ext_global" "std::send_http_request" {
  url = input.rpc_api_url
  method = "POST"
  body = {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "getAccountInfo",
    "params": [
      variable.m_ext_global.pda,
      { "encoding": "base64" }
    ]
  }
}

output "m_ext_global_account_info" {
  value = action.get_m_ext_global.response_body
}

